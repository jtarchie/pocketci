{
  "name": "pocketci-server-static",
  "version": "1.0.0",
  "private": true,
  "description": "Static assets for PocketCI server",
  "scripts": {
    "build": "npm run build:css && npm run build:js",
    "build:css": "tailwindcss --cwd ../ -i static/src/index.css -o static/dist/bundle.css --minify --optimize",
    "build:js": "esbuild src/index.js --bundle --minify --outfile=dist/bundle.js --format=iife --global-name=PocketCI --target=es2017"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "htmx.org": "^2.0.8",
    "idiomorph": "^0.7.4"
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.2.2",
    "esbuild": "0.27.4",
    "tailwindcss": "4.2.2"
  }
}
